@{
    ViewData["Title"] = "Flight Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container mx-auto px-4 sm:px-6 max-w-3xl py-8">
    <div class="bg-white rounded-md shadow-md border border-primary-200 p-6 sm:p-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-3">Unable To Load Flight Data</h2>
        <p class="text-dark-700 mb-6">Please try again in a moment or update your search filters.</p>
        <a href="/api/flight" class="gradient-primary text-white font-semibold py-2.5 px-6 rounded-md inline-flex items-center shadow-md hover:shadow-lg transition-normal">
            <i class="fas fa-redo-alt mr-2"></i> Back To Flight Search
        </a>
    </div>
</section>
