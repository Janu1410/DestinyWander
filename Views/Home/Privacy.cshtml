@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="container mx-auto px-4 sm:px-6 max-w-4xl py-8">
    <div class="bg-white rounded-md shadow-md border border-primary-200 p-6 sm:p-8">
        <h1 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-4">Privacy Policy</h1>
        <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-6 w-32"></div>
        <p class="text-dark-700 mb-4">
            Destiny Wander uses your information only to process bookings, improve your travel experience, and provide support.
            We do not sell personal information to third parties.
        </p>
        <p class="text-dark-700 mb-4">
            Payment details are processed through secure channels. Account and booking data are used only for communication,
            confirmations, and service delivery.
        </p>
        <p class="text-dark-700">
            For privacy requests, please contact support with your registered email and booking details.
        </p>
    </div>
</section>
