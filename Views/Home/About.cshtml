@{
    ViewData["Title"] = "About";
}

<section class="container mx-auto px-4 sm:px-6 max-w-6xl py-6">
    <section class="bg-white rounded-md shadow-md p-6 sm:p-8 mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-4 flex items-center">
            <i class="fas fa-users text-primary mr-2"></i> Who We Are
        </h2>
        <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-6 w-32"></div>
        <p class="text-dark-700 text-base sm:text-lg leading-relaxed mb-4">
            Destiny Wander was founded to make travel easy and memorable. From peaceful escapes to
            adventure-heavy itineraries, we build experiences around what travelers actually want.
        </p>
        <p class="text-dark-700 text-base sm:text-lg leading-relaxed">
            We focus on practical planning, transparent pricing, and reliable support so every journey
            stays smooth from booking to return.
        </p>
    </section>

    <section class="bg-primary-100 rounded-md shadow-md p-6 sm:p-8 mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-4 flex items-center">
            <i class="fas fa-bullseye text-primary mr-2"></i> Our Mission
        </h2>
        <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-6 w-32"></div>
        <p class="text-dark-700 text-base sm:text-lg leading-relaxed">
            To help people travel confidently with curated options for flights, hotels, taxis, and tour
            packages in one place.
        </p>
    </section>

</section>
