@model backend.Package.Models.ErrorViewModel
@{
    ViewData["Title"] = "Package Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container mx-auto px-4 sm:px-6 max-w-3xl py-8">
    <div class="bg-white rounded-md shadow-md border border-primary-200 p-6 sm:p-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-3">Package Request Failed</h2>
        <p class="text-dark-700 mb-4">We could not complete the package request. Please try again.</p>
        @if (Model?.ShowRequestId == true)
        {
            <p class="text-sm text-gray-600 mb-4">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }
        <a href="/Tour/Index" class="gradient-primary text-white font-semibold py-2.5 px-6 rounded-md inline-flex items-center shadow-md hover:shadow-lg transition-normal">
            <i class="fas fa-route mr-2"></i> Browse Packages
        </a>
    </div>
</section>
