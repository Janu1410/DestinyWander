@{
    ViewData["Title"] = "Booking Confirmed";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            /* Terra Cotta Color Palette */
            --primary: #DF6951;
            --primary-100: #F9E2DD;
            --primary-200: #F2C5BB;
            --primary-300: #EBA799;
            --primary-400: #E58A77;
            --primary-600: #C85E47;
            --primary-700: #B1533D;
            --primary-800: #9A4833;
            --white: #FFFFFF;
            --light-100: #FDF9F8;
            --light-200: #FAF3F2;
            --light-300: #F5EDEB;
            --gray-400: #D7CECB;
            --gray-500: #A89B97;
            --gray-600: #796A65;
            --dark-700: #4A3D39;
            --dark-800: #2E2522;
            --dark-900: #1A1210;
            --border-radius-sm: 6px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
            --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
            --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        /* Custom Tailwind utilities */
        .bg-primary { background-color: var(--primary); }
        .bg-primary-100 { background-color: var(--primary-100); }
        .bg-primary-200 { background-color: var(--primary-200); }
        .bg-primary-600 { background-color: var(--primary-600); }
        .text-primary { color: var(--primary); }
        .text-primary-600 { color: var(--primary-600); }
        .text-dark-700 { color: var(--dark-700); }
        .text-dark-800 { color: var(--dark-800); }
        .border-primary-200 { border-color: var(--primary-200); }
        .shadow-sm { box-shadow: var(--shadow-sm); }
        .shadow-md { box-shadow: var(--shadow-md); }
        .shadow-lg { box-shadow: var(--shadow-lg); }
        .transition-normal { transition: var(--transition-normal); }

        /* Gradient for headers and buttons */
        .gradient-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
        }

      

        /* Ensure Poppins font */
        body {
            font-family: 'Poppins', sans-serif;
        }
    </style>
</head>
<body class="bg-light-100 text-dark-800 font-poppins antialiased min-h-screen py-12">
    <div class="container mx-auto px-4 sm:px-6 max-w-2xl fade-in">
        <div class="bg-white rounded-md shadow-md p-6 sm:p-8 border border-primary-200">
            <h2 class="text-2xl sm:text-3xl font-bold text-primary-600 mb-4 flex items-center justify-center">
                <i class="fas fa-check-circle mr-2"></i> Booking Confirmed!
            </h2>
            <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-6 mx-auto w-32"></div>

            @if (ViewBag.Message != null)
            {
                <p class="text-lg text-dark-700 bg-primary-100 rounded-md p-4 mb-4">@ViewBag.Message</p>
                <p class="text-lg text-dark-700 bg-primary-100 rounded-md p-4 mb-4">Our holiday expert will contact you soon!</p>
            }
            else
            {
                <p class="text-lg text-dark-700 bg-primary-100 rounded-md p-4 mb-4">Thank you for booking with us. Our holiday expert will contact you soon!</p>
            }

            <a href="@Url.Action("Index", "Home")" class="gradient-primary text-white font-semibold py-2 px-4 sm:px-6 rounded-md mt-6 inline-flex items-center shadow-md hover:shadow-lg transition-normal transform hover:-translate-y-1 focus:ring-2 focus:ring-primary-200 focus:outline-none" aria-label="Return to tour packages home page">
                <i class="fas fa-home mr-2"></i> Back to Home
            </a>
        </div>
    </div>
</body>
</html>
