@model List<backend.Package.Models.TourPackage>

@{
    ViewData["Title"] = "Holiday Packages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
        :root {
            /* Terra Cotta Color Palette */
            --primary: #DF6951;
            --primary-100: #F9E2DD;
            --primary-200: #F2C5BB;
            --primary-300: #EBA799;
            --primary-400: #E58A77;
            --primary-600: #C85E47;
            --primary-700: #B1533D;
            --primary-800: #9A4833;
            --white: #FFFFFF;
            --light-100: #FDF9F8;
            --light-200: #FAF3F2;
            --light-300: #F5EDEB;
            --gray-400: #D7CECB;
            --gray-500: #A89B97;
            --gray-600: #796A65;
            --dark-700: #4A3D39;
            --dark-800: #2E2522;
            --dark-900: #1A1210;
            --border-radius-sm: 6px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
            --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
            --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        /* Custom Tailwind utilities */
        .bg-primary { background-color: var(--primary); }
        .bg-primary-100 { background-color: var(--primary-100); }
        .bg-primary-200 { background-color: var(--primary-200); }
        .bg-primary-600 { background-color: var(--primary-600); }
        .text-primary { color: var(--primary); }
        .text-primary-600 { color: var(--primary-600); }
        .text-dark-700 { color: var(--dark-700); }
        .text-dark-800 { color: var(--dark-800); }
        .border-light-300 { border-color: var(--light-300); }
        .shadow-sm { box-shadow: var(--shadow-sm); }
        .shadow-md { box-shadow: var(--shadow-md); }
        .shadow-lg { box-shadow: var(--shadow-lg); }
        .transition-normal { transition: var(--transition-normal); }

        /* Gradient for headers */
        .gradient-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
        }

        /* Fade-in animation */
        

        /* Ensure Poppins font */
        body {
            font-family: 'Poppins', sans-serif;
        }
    </style>

<div class="container mx-auto px-4 sm:px-6 max-w-6xl">
        <!-- Header -->
        <div class="mb-8 fade-in">
            <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 flex items-center">
                <i class="fas fa-suitcase text-primary mr-2"></i> Popular Holiday Packages
            </h2>
            <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mt-2 w-32"></div>
        </div>

        <!-- Package Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @if (Model != null && Model.Any())
            {
                foreach (var pkg in Model)
                {
                    <a href="@Url.Action("Details", "Tour", new { id = pkg.Id })" class="no-underline text-inherit block fade-in" aria-label="View details for @(pkg.Title ?? "holiday package")">
                        <div class="bg-white rounded-md shadow-md overflow-hidden transition-normal hover:shadow-lg hover:scale-105">
                            <img src="@(pkg.ImageUrl ?? "https://via.placeholder.com/300x200")" alt="@(pkg.Title ?? "Holiday Package")" class="w-full h-48 object-cover rounded-t-md">
                            <div class="p-4">
                                <h5 class="text-lg sm:text-xl font-bold text-dark-800 mb-2 truncate">@(pkg.Title ?? "N/A")</h5>
                                <p class="text-dark-700 text-sm sm:text-base flex items-center mb-2">
                                    <i class="fas fa-rupee-sign text-primary mr-1"></i> Starting at &#8377;@(pkg.Price.ToString("0") ?? "N/A") Per Person
                                </p>
                                <span class="text-primary-600 text-sm flex items-center">
                                    <i class="fas fa-star mr-1"></i> @(pkg.DiscountLabel ?? "N/A")
                                </span>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <p class="text-dark-700 text-center col-span-full fade-in">No holiday packages found.</p>
            }
        </div>
    </div>


