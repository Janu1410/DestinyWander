@model backend.Package.Models.TourPackage

@{
    ViewData["Title"] = Model?.Title ?? "Tour Package Details";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            /* Terra Cotta Color Palette */
            --primary: #DF6951;
            --primary-100: #F9E2DD;
            --primary-200: #F2C5BB;
            --primary-300: #EBA799;
            --primary-400: #E58A77;
            --primary-600: #C85E47;
            --primary-700: #B1533D;
            --primary-800: #9A4833;
            --white: #FFFFFF;
            --light-100: #FDF9F8;
            --light-200: #FAF3F2;
            --light-300: #F5EDEB;
            --gray-400: #D7CECB;
            --gray-500: #A89B97;
            --gray-600: #796A65;
            --dark-700: #4A3D39;
            --dark-800: #2E2522;
            --dark-900: #1A1210;
            --border-radius-sm: 6px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
            --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
            --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        /* Custom Tailwind utilities */
        .bg-primary { background-color: var(--primary); }
        .bg-primary-100 { background-color: var(--primary-100); }
        .bg-primary-200 { background-color: var(--primary-200); }
        .bg-primary-600 { background-color: var(--primary-600); }
        .text-primary { color: var(--primary); }
        .text-primary-600 { color: var(--primary-600); }
        .text-dark-700 { color: var(--dark-700); }
        .text-dark-800 { color: var(--dark-800); }
        .border-light-300 { border-color: var(--light-300); }
        .border-primary-200 { border-color: var(--primary-200); }
        .border-primary+primary-600 { border-color: var(--primary-600); }
        .shadow-sm { box-shadow: var(--shadow-sm); }
        .shadow-md { box-shadow: var(--shadow-md); }
        .shadow-lg { box-shadow: var(--shadow-lg); }
        .transition-normal { transition: var(--transition-normal); }

        /* Gradient for headers and buttons */
        .gradient-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
        }

        /* Fade-in animation */
        .fade-in {
            animation: fadeIn 0.5s ease-in-out;
        }


        /* Hero section overlay */
       
    </style>
</head>
<body class="bg-light-100 text-dark-800 font-poppins antialiased min-h-screen py-12">
    <div class="container mx-auto px-4 sm:px-6 max-w-6xl">
        <!-- Hero Section -->
        <div class="relative h-80 sm:h-96 rounded-md mb-8 overflow-hidden fade-in hero-overlay">
            <img src="@(Model?.ImageUrl ?? "https://via.placeholder.com/1200x400")" alt="@(Model?.Title ?? "Tour Package")" class="absolute inset-0 w-full h-full object-cover object-center">
            <div class="relative z-20 flex items-center justify-center h-full text-center">
                <div>
                    <h1 class="text-3xl sm:text-4xl font-bold text-white text-shadow-lg">@(Model?.Title ?? "N/A")</h1>
                </div>
            </div>
        </div>

        <!-- Basic Info -->
        <div class="flex flex-col lg:flex-row gap-6 mb-8 fade-in">
            <div class="flex-1 bg-primary-100 rounded-md p-4 sm:p-6">
                <p class="text-base sm:text-lg text-dark-700 flex items-center mb-2">
                    <i class="fas fa-route text-primary mr-2"></i>
                    <strong class="mr-2">Route:</strong> @(Model?.Itinerary ?? "N/A")
                </p>
                <p class="text-base sm:text-lg text-dark-700 flex items-center">
                    <i class="fas fa-hotel text-primary mr-2"></i>
                    <strong class="mr-2">Hotel:</strong> @(Model?.Hotel ?? "N/A")
                </p>
            </div>
            <div class="lg:w-1/3 text-left lg:text-right">
                <h5 class="text-xl font-bold text-primary-600">₹@(Model?.Price.ToString("0") ?? "N/A")</h5>
                <p class="text-gray-500 line-through text-sm">₹@(Model?.OriginalPrice.ToString("0") ?? "N/A")</p>
                <span class="inline-block bg-primary-600 text-white text-xs font-semibold px-2 py-1 rounded-md mt-2">
                    <i class="fas fa-tag mr-1"></i> @(Model?.DiscountLabel ?? "N/A")
                </span>
            </div>
        </div>

        <!-- Day Plan -->
        <div class="mb-8 fade-in">
            <h4 class="text-2xl font-bold text-dark-800 mb-4">Your Journey</h4>
            <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-6 w-32"></div>
            <div class="grid grid-cols-1 gap-6">
                @if (Model?.DayPlan != null && Model.DayPlan.Any())
                {
                    foreach (var day in Model.DayPlan)
                    {
                        <div class="bg-white rounded-md shadow-md p-4 sm:p-6 border border-primary-200 transition-normal hover:shadow-lg fade-in">
                            <div class="text-lg font-bold text-primary-600 mb-4">@(day?.Day ?? "N/A")</div>
                            <div class="space-y-3">
                                <div class="bg-primary-100 border-l-4 border-primary-600 p-3 rounded-r-md">
                                    <span class="text-primary-600 font-semibold flex items-center">
                                        <i class="fas fa-compass mr-2"></i> Activity:
                                    </span>
                                    <span class="text-dark-700">@(day?.Activity ?? "N/A")</span>
                                </div>
                                <div class="bg-primary-100 border-l-4 border-primary-600 p-3 rounded-r-md">
                                    <span class="text-primary-600 font-semibold flex items-center">
                                        <i class="fas fa-utensils mr-2"></i> Meal:
                                    </span>
                                    <span class="text-dark-700">@(day?.Meal ?? "N/A")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(day?.Transfer))
                                {
                                    <div class="bg-primary-100 border-l-4 border-primary-600 p-3 rounded-r-md">
                                        <span class="text-primary-600 font-semibold flex items-center">
                                            <i class="fas fa-taxi mr-2"></i> Transfer:
                                        </span>
                                        <span class="text-dark-700">@day.Transfer</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-dark-700 text-center">No day plan available.</p>
                }
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center fade-in">
            <a href="@Url.Action("Checkout", "Payment", new { id = Model?.Id })" class="gradient-primary text-white font-semibold py-2 px-4 sm:px-6 rounded-md inline-flex items-center shadow-md hover:shadow-lg transition-normal transform hover:-translate-y-1 focus:ring-2 focus:ring-primary-200 focus:outline-none" aria-label="Proceed to payment for @(Model?.Title ?? "tour package")">
                <i class="fas fa-credit-card mr-2"></i> Proceed to Payment
            </a>
        </div>
    </div>
</body>
</html>
