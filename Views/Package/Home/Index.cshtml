@model List<backend.Package.Models.TourPackage>

@{
    ViewData["Title"] = "Featured Packages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container mx-auto px-4 sm:px-6 max-w-6xl py-8">
    <div class="mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800">Featured Holiday Packages</h2>
        <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mt-2 w-32"></div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var item in Model)
            {
                <article class="bg-white rounded-md shadow-md overflow-hidden border border-primary-200 transition-normal hover:shadow-lg">
                    <img src="@(item.ImageUrl ?? "https://via.placeholder.com/600x360")" alt="@(item.Title ?? "Tour package")" class="w-full h-48 object-cover" />
                    <div class="p-4">
                        <h3 class="text-lg font-bold text-dark-800 mb-2">@(item.Title ?? "Package")</h3>
                        <p class="text-dark-700 text-sm mb-2">@item.Duration</p>
                        <p class="text-dark-700 text-sm mb-4">@(item.Itinerary ?? "Itinerary details coming soon.")</p>
                        <p class="text-dark-800 font-semibold mb-4">
                            &#8377;@item.Price <del class="text-gray-500 font-normal">&#8377;@item.OriginalPrice</del>
                            <span class="text-primary-600">@item.DiscountLabel</span>
                        </p>
                        <a href="@Url.Action("Details", "Tour", new { id = item.Id })" class="gradient-primary text-white font-semibold py-2 px-4 rounded-md inline-flex items-center">
                            View Details
                        </a>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="bg-white rounded-md shadow-md border border-primary-200 p-6 text-dark-700">
            No packages are available right now.
        </div>
    }
</section>
