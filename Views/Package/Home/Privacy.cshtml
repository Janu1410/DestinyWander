@{
    ViewData["Title"] = "Package Privacy";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container mx-auto px-4 sm:px-6 max-w-4xl py-8">
    <div class="bg-white rounded-md shadow-md border border-primary-200 p-6 sm:p-8">
        <h1 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-4">Holiday Package Privacy</h1>
        <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-6 w-32"></div>
        <p class="text-dark-700 mb-4">
            Package inquiries and booking information are used only to provide itinerary support, payment confirmation,
            and travel communication.
        </p>
        <p class="text-dark-700 mb-4">
            We keep only the minimum data needed for booking operations and customer support.
            Sensitive details are handled with secure processing.
        </p>
        <p class="text-dark-700">
            If you need your package-related data updated or removed, contact support with your booking reference.
        </p>
    </div>
</section>
