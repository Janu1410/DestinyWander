@{
    ViewData["Title"] = "Home Page";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            /* Terra Cotta Color Palette */
            --primary: #DF6951;
            --primary-100: #F9E2DD;
            --primary-200: #F2C5BB;
            --primary-300: #EBA799;
            --primary-400: #E58A77;
            --primary-600: #C85E47;
            --primary-700: #B1533D;
            --primary-800: #9A4833;
            --white: #FFFFFF;
            --light-100: #FDF9F8;
            --light-200: #FAF3F2;
            --light-300: #F5EDEB;
            --gray-400: #D7CECB;
            --gray-500: #A89B97;
            --gray-600: #796A65;
            --dark-700: #4A3D39;
            --dark-800: #2E2522;
            --dark-900: #1A1210;
            --border-radius-sm: 6px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
            --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
            --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        /* Custom Tailwind utilities */
        .bg-primary { background-color: var(--primary); }
        .bg-primary-100 { background-color: var(--primary-100); }
        .bg-primary-200 { background-color: var(--primary-200); }
        .bg-primary-600 { background-color: var(--primary-600); }
        .text-primary { color: var(--primary); }
        .text-primary-600 { color: var(--primary-600); }
        .text-dark-700 { color: var(--dark-700); }
        .text-dark-800 { color: var(--dark-800); }
        .border-light-300 { border-color: var(--light-300); }
        .border-primary-200 { border-color: var(--primary-200); }
        .shadow-sm { box-shadow: var(--shadow-sm); }
        .shadow-md { box-shadow: var(--shadow-md); }
        .shadow-lg { box-shadow: var(--shadow-lg); }
        .transition-normal { transition: var(--transition-normal); }

        /* Gradient for headers and buttons */
        .gradient-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
        }

      

        /* Fade-in animation */
       
        /* Ensure Poppins font */
        body {
            font-family: 'Poppins', sans-serif;
        }
    </style>
</head>
<body class="bg-light-100 text-dark-800 font-poppins antialiased min-h-screen">
    <!-- Error Message -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="container mx-auto px-4 sm:px-6 max-w-6xl mt-4">
            <div class="bg-red-100 text-red-600 p-4 rounded-md shadow-md fade-in">@TempData["ErrorMessage"]</div>
        </div>
    }

    <!-- Header Section -->
    <header class="relative h-96 sm:h-[32rem] hero-overlay fade-in">
        <img src="~/imagesP/Wallpaper.png" alt="Travel destination" class="absolute inset-0 w-full h-full object-cover object-center">
        <!-- Navbar -->
        <nav class="relative z-20 container mx-auto px-4 sm:px-6 flex items-center justify-between py-4">
            <div class="text-2xl font-bold text-white">Destiny Wander</div>
            <div class="hidden md:flex space-x-6">
                <a href="/Home/Index" class="text-white hover:text-primary-200 transition-normal flex items-center"><i class="fas fa-home mr-1"></i> Home</a>
                <a href="/Home/About" class="text-white hover:text-primary-200 transition-normal flex items-center"><i class="fas fa-info-circle mr-1"></i> About</a>
                <a href="@Url.Action("Index", "Tour")" class="text-white hover:text-primary-200 transition-normal flex items-center"><i class="fas fa-suitcase mr-1"></i> Upcoming Packages</a>
            </div>
            <button class="md:hidden text-white focus:outline-none" id="menu-toggle" aria-label="Toggle navigation menu">
                <i class="fas fa-bars text-2xl"></i>
            </button>
        </nav>
        <!-- Mobile Menu -->
        <div class="hidden md:hidden bg-dark-900 bg-opacity-90 absolute top-16 left-0 w-full z-20" id="mobile-menu">
            <div class="flex flex-col items-center space-y-4 py-4">
                <a href="#" class="text-white hover:text-primary-200 transition-normal flex items-center"><i class="fas fa-home mr-1"></i> Home</a>
                <a href="#" class="text-white hover:text-primary-200 transition-normal flex items-center"><i class="fas fa-info-circle mr-1"></i> About</a>
                <a href="#" class="text-white hover:text-primary-200 transition-normal flex items-center"><i class="fas fa-concierge-bell mr-1"></i> Services</a>
                <a href="@Url.Action("Index", "Tour")" class="text-white hover:text-primary-200 transition-normal flex items-center"><i class="fas fa-suitcase mr-1"></i> Upcoming Packages</a>
            </div>
        </div>
        <!-- Search Form -->
        <div class="relative z-20 container mx-auto px-4 sm:px-6 flex items-center justify-center h-full">
            <form method="get" action="@Url.Action("SearchCity", "Hotel")" class="bg-white rounded-md shadow-lg p-4 sm:p-6 w-full max-w-4xl fade-in">
                <div class="flex flex-col sm:flex-row gap-4">
                    <div class="flex-1 relative">
                        <label for="location" class="block text-sm font-medium text-dark-700 mb-1">Location</label>
                        <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-map-marker-alt text-gray-500"></i>
                        </div>
                        <input type="text" name="location" id="searchBox" placeholder="Where do you want to stay?" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                        <div class="absolute w-full bg-white rounded-md shadow-md mt-1 hidden" id="suggestions">
                            <p class="px-4 py-2 text-sm text-dark-700">Search: <strong id="searchQuery"></strong></p>
                            <div id="popular-list" class="px-4 py-2"></div>
                        </div>
                    </div>
                    <div class="flex-1">
                        <label for="checkIn" class="block text-sm font-medium text-dark-700 mb-1">Check-In</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-calendar-alt text-gray-500"></i>
                            </div>
                            <input type="date" name="checkIn" id="checkIn" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                        </div>
                    </div>
                    <div class="flex-1">
                        <label for="checkOut" class="block text-sm font-medium text-dark-700 mb-1">Check-Out</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-calendar-alt text-gray-500"></i>
                            </div>
                            <input type="date" name="checkOut" id="checkOut" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                        </div>
                    </div>
                    <div class="flex-1">
                        <label for="rooms" class="block text-sm font-medium text-dark-700 mb-1">Rooms</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-door-open text-gray-500"></i>
                            </div>
                            <input type="number" name="rooms" id="rooms" min="1" max="5" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                        </div>
                    </div>
                    <div class="flex-1">
                        <label for="priceRange" class="block text-sm font-medium text-dark-700 mb-1">Price Per Night</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-rupee-sign text-gray-500"></i>
                            </div>
                            <select name="priceRange" id="priceRange" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal">
                                <option value="">Select</option>
                                <option value="0-1500">₹0–₹1500</option>
                                <option value="1500-2500">₹1500–₹2500</option>
                                <option value="2500-5000">₹2500–₹5000</option>
                                <option value="5000+">₹5000+</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="text-center mt-4">
                    <button type="submit" class="gradient-primary text-white font-semibold py-2 px-6 rounded-md shadow-md hover:shadow-lg transition-normal transform hover:-translate-y-1 focus:ring-2 focus:ring-primary-200 focus:outline-none" aria-label="Search hotels">
                        <i class="fas fa-search mr-2"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </header>

    <!-- Destinations Section -->
    <section class="container mx-auto px-4 sm:px-6 max-w-6xl py-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-4 fade-in">Popular Destinations</h2>
        <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-8 w-32 fade-in"></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @{
                var destinations = new[]
                {
                    new { Name = "Goa", Image = "goa.jpg", Action = "Goa" },
                    new { Name = "Ooty", Image = "ooty.jpg", Action = "Ooty" },
                    new { Name = "Manali", Image = "manali.jpg", Action = "Manali" },
                    new { Name = "Jaipur", Image = "jaipur.jpg", Action = "Jaipur" },
                    new { Name = "Mumbai", Image = "mumbai.jpg", Action = "Mumbai" },
                    new { Name = "Delhi", Image = "delhi.jpg", Action = "Delhi" },
                    new { Name = "Bangalore", Image = "bangalore.jpg", Action = "Bangalore" },
                    new { Name = "Shimla", Image = "shimla.jpg", Action = "Shimla" },
                    new { Name = "Ujjain", Image = "ujjain.jpg", Action = "Ujjain" },
                    new { Name = "Udaipur", Image = "udaipur.jpg", Action = "Udaipur" }
                };
            }
            @foreach (var dest in destinations)
            {
                <a href="/api/hotel/@(dest.Action)" class="no-underline text-inherit block fade-in" aria-label="View hotels in @dest.Name">
                    <div class="bg-white rounded-md shadow-md overflow-hidden transition-normal hover:shadow-lg hover:scale-105">
                        <img src="~/images/@(dest.Image)"alt="@dest.Name destination" class="w-full h-48 object-cover rounded-t-md">
                        <div class="p-4">
                            <h3 class="text-lg sm:text-xl font-bold text-primary-600">@dest.Name</h3>
                            <p class="text-dark-700 text-sm">Hotels, Budget Hotels, Resorts, Best Hotels, Villas</p>
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="container mx-auto px-4 sm:px-6 max-w-6xl py-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-4 fade-in">Frequently Asked Questions</h2>
        <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-8 w-32 fade-in"></div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-primary-100 rounded-md shadow-md p-4 sm:p-6 fade-in transition-normal hover:shadow-lg">
                <h3 class="text-lg sm:text-xl font-bold text-dark-800 mb-2 flex items-center"><i class="fas fa-question-circle text-primary mr-2"></i> How to book a hotel?</h3>
                <p class="text-dark-700 text-sm sm:text-base">
                    Booking a hotel online is easy through this website. Tap on the Hotels section and enter the details of the city, area, or hotel. Fill out the check-in and check-out dates, along with other details and tap Search. Use the Sort & Filter options to book one as per your convenience. You can also choose hotels according to user reviews and ratings.
                </p>
            </div>
            <div class="bg-primary-100 rounded-md shadow-md p-4 sm:p-6 fade-in transition-normal hover:shadow-lg">
                <h3 class="text-lg sm:text-xl font-bold text-dark-800 mb-2 flex items-center"><i class="fas fa-question-circle text-primary mr-2"></i> How to find the cheapest hotel deals?</h3>
                <p class="text-dark-700 text-sm sm:text-base">
                    We offer several discounts on budget hotels. To find the cheapest hotels, use the Sort & Filter option and adjust the Price range from ₹0 to ₹500 or ₹0 to ₹1000. Choose amenities like Wi-Fi, room service, and in-house restaurants. The list will show the cheapest options first. Sort by prices from Low to High to find great discounts.
                </p>
            </div>
        </div>
        <hr class="border-light-300 my-8 fade-in">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-primary-100 rounded-md shadow-md p-4 sm:p-6 fade-in transition-normal hover:shadow-lg">
                <h3 class="text-lg sm:text-xl font-bold text-dark-800 mb-2 flex items-center"><i class="fas fa-question-circle text-primary mr-2"></i> How to find the best hotels near me?</h3>
                <p class="text-dark-700 text-sm sm:text-base">
                    For first-time travelers, finding hotels in the best areas is easy. For example, in Goa, search for hotels near popular beaches like Baga and Calangute. The search results will list hotels in ideal areas for couples and families. In Mumbai, book hotels near business districts, tourist areas, or transportation hubs.
                </p>
            </div>
            <div class="bg-primary-100 rounded-md shadow-md p-4 sm:p-6 fade-in transition-normal hover:shadow-lg">
                <h3 class="text-lg sm:text-xl font-bold text-dark-800 mb-2 flex items-center"><i class="fas fa-question-circle text-primary mr-2"></i> Where can I find current deals?</h3>
                <p class="text-dark-700 text-sm sm:text-base">
                    We offer daily deals on luxury and budget hotels across India. These deals are time-limited and may change daily. Check for properties with an ‘Exclusive Deal’ label after narrowing down your choices to see available offers.
                </p>
            </div>
        </div>
    </section>

    <!-- Footer Section -->
    <footer class="bg-dark-900 text-white py-12 fade-in">
        <div class="container mx-auto px-4 sm:px-6 max-w-6xl">
            <div class="flex flex-col md:flex-row justify-between gap-8">
                <!-- Brand -->
                <div class="flex-1">
                    <h2 class="text-2xl font-bold">Travel<span class="text-primary">→</span></h2>
                    <p class="text-gray-400 text-sm mt-2">Travel helps companies manage payments easily.</p>
                    <div class="flex space-x-4 mt-4">
                        <a href="#" aria-label="Visit our LinkedIn page"><i class="fab fa-linkedin text-white hover:text-primary-200 text-xl transition-normal"></i></a>
                        <a href="#" aria-label="Visit our Instagram page"><i class="fab fa-instagram text-white hover:text-primary-200 text-xl transition-normal"></i></a>
                    </div>
                </div>
                <!-- Company Links -->
                <div class="flex-1">
                    <h3 class="text-lg font-semibold text-white mb-4">Company</h3>
                    <ul class="space-y-2">
                        <li><a href="#" class="text-gray-400 hover:text-primary-200 transition-normal">About Us</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-primary-200 transition-normal">Careers</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-primary-200 transition-normal">Blog</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-primary-200 transition-normal">Pricing</a></li>
                    </ul>
                </div>
                <!-- Destinations Links -->
                <div class="flex-1">
                    <h3 class="text-lg font-semibold text-white mb-4">Destinations</h3>
                    <ul class="space-y-2">
                        <li><a href="#" class="text-gray-400 hover:text-primary-200 transition-normal">Maldives</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-primary-200 transition-normal">Los Angeles</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-primary-200 transition-normal">Las Vegas</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-primary-200 transition-normal">Toronto</a></li>
                    </ul>
                </div>
            </div>
            <hr class="border-gray-600 my-8">
            <p class="text-center text-gray-400 text-sm">Copyright © Xpro 2025. All Rights Reserved.</p>
        </div>
    </footer>

    <!-- JavaScript for Search Suggestions and Mobile Menu -->
    <script>
        // Mobile Menu Toggle
        document.getElementById('menu-toggle').addEventListener('click', () => {
            const mobileMenu = document.getElementById('mobile-menu');
            mobileMenu.classList.toggle('hidden');
        });

        // Search Suggestions
        const searchBox = document.getElementById('searchBox');
        const suggestionsBox = document.getElementById('suggestions');
        const searchQuery = document.getElementById('searchQuery');
        const popularList = document.getElementById('popular-list');

        const cities = ['Goa', 'Ooty', 'Manali', 'Jaipur', 'Mumbai', 'Delhi', 'Bangalore', 'Shimla', 'Ujjain', 'Udaipur'];

        searchBox.addEventListener('input', () => {
            const query = searchBox.value.toLowerCase().trim();
            suggestionsBox.classList.toggle('hidden', query.length === 0);
            searchQuery.textContent = query || 'Type a city...';

            if (query) {
                const filteredCities = cities.filter(city => city.toLowerCase().includes(query));
                popularList.innerHTML = filteredCities.length
                    ? filteredCities.map(city => `<p class="text-dark-700 hover:text-primary-600 hover:bg-primary-100 px-2 py-1 cursor-pointer transition-normal">${city}</p>`).join('')
                    : '<p class="text-dark-700">No cities found</p>';
            } else {
                popularList.innerHTML = cities.map(city => `<p class="text-dark-700 hover:text-primary-600 hover:bg-primary-100 px-2 py-1 cursor-pointer transition-normal">${city}</p>`).join('');
            }
        });

        popularList.addEventListener('click', (e) => {
            if (e.target.tagName === 'P') {
                searchBox.value = e.target.textContent;
                suggestionsBox.classList.add('hidden');
            }
        });

        // Hide suggestions when clicking outside
        document.addEventListener('click', (e) => {
            if (!suggestionsBox.contains(e.target) && e.target !== searchBox) {
                suggestionsBox.classList.add('hidden');
            }
        });
    </script>
    <script src="/_framework/aspnetcore-browser-refresh.js"></script>
</body>
</html>
