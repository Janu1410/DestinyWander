@{
    ViewData["Title"] = "Hotels";
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="container mx-auto px-4 sm:px-6 max-w-6xl mt-4">
        <div class="bg-red-100 text-red-600 p-4 rounded-md shadow-md">@TempData["ErrorMessage"]</div>
    </div>
}

<section class="container mx-auto px-4 sm:px-6 max-w-6xl py-6">
    <section class="bg-white rounded-md shadow-lg p-4 sm:p-6 mb-10">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-2">Find Your Stay</h2>
        <p class="text-dark-700 mb-5">Search hotels by city, dates, rooms, and budget.</p>

        <form method="get" action="@Url.Action("SearchCity", "Hotel")" class="space-y-4" data-requires-auth="true" data-auth-message="Please sign up or log in to search hotels.">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
                <div class="relative lg:col-span-2">
                    <label for="searchBox" class="block text-sm font-medium text-dark-700 mb-1">Location</label>
                    <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-map-marker-alt text-gray-500"></i>
                    </div>
                    <input type="text" name="location" id="searchBox" placeholder="Where do you want to stay?" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                    <div class="absolute w-full bg-white rounded-md shadow-md mt-1 hidden z-20" id="suggestions">
                        <p class="px-4 py-2 text-sm text-dark-700">Search: <strong id="searchQuery"></strong></p>
                        <div id="popular-list" class="px-4 py-2"></div>
                    </div>
                </div>

                <div>
                    <label for="checkIn" class="block text-sm font-medium text-dark-700 mb-1">Check-In</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-calendar-alt text-gray-500"></i>
                        </div>
                        <input type="date" name="checkIn" id="checkIn" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                    </div>
                </div>

                <div>
                    <label for="checkOut" class="block text-sm font-medium text-dark-700 mb-1">Check-Out</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-calendar-alt text-gray-500"></i>
                        </div>
                        <input type="date" name="checkOut" id="checkOut" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                    </div>
                </div>

                <div>
                    <label for="rooms" class="block text-sm font-medium text-dark-700 mb-1">Rooms</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-door-open text-gray-500"></i>
                        </div>
                        <input type="number" name="rooms" id="rooms" min="1" max="5" value="1" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-end">
                <div>
                    <label for="priceRange" class="block text-sm font-medium text-dark-700 mb-1">Price Per Night</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-rupee-sign text-gray-500"></i>
                        </div>
                        <select name="priceRange" id="priceRange" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal">
                            <option value="">Select</option>
                            <option value="0-1500">0-1500</option>
                            <option value="1500-2500">1500-2500</option>
                            <option value="2500-5000">2500-5000</option>
                            <option value="5000+">5000+</option>
                        </select>
                    </div>
                </div>

                <div class="text-left sm:text-right">
                    <button type="submit" class="gradient-primary text-white font-semibold py-2 px-6 rounded-md shadow-md hover:shadow-lg transition-normal transform hover:-translate-y-1" aria-label="Search hotels">
                        <i class="fas fa-search mr-2"></i> Search
                    </button>
                </div>
            </div>
        </form>
    </section>

    <section class="mb-10">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-4">Popular Destinations</h2>
        <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-8 w-32"></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @{
                var destinations = new[]
                {
                    new { Name = "Goa", Image = "goa.jpg", Action = "Goa" },
                    new { Name = "Ooty", Image = "ooty.jpg", Action = "Ooty" },
                    new { Name = "Manali", Image = "manali.jpg", Action = "Manali" },
                    new { Name = "Jaipur", Image = "jaipur.jpg", Action = "Jaipur" },
                    new { Name = "Mumbai", Image = "mumbai.jpg", Action = "Mumbai" },
                    new { Name = "Delhi", Image = "delhi.jpg", Action = "Delhi" },
                    new { Name = "Banglore", Image = "bangalore.jpg", Action = "Banglore" },
                    new { Name = "Shimla", Image = "shimla.jpg", Action = "Shimla" },
                    new { Name = "Ujjain", Image = "ujjain.jpg", Action = "Ujjain" },
                    new { Name = "Udaipur", Image = "udaipur.jpg", Action = "Udaipur" }
                };
            }
            @foreach (var dest in destinations)
            {
                <a href="/api/hotel/@(dest.Action)" class="no-underline text-inherit block" aria-label="View hotels in @dest.Name">
                    <div class="bg-white rounded-md shadow-md overflow-hidden transition-normal hover:shadow-lg hover:scale-105">
                        <img src="~/images/@(dest.Image)" alt="@dest.Name destination" class="w-full h-48 object-cover rounded-t-md">
                        <div class="p-4">
                            <h3 class="text-lg sm:text-xl font-bold text-primary-600">@dest.Name</h3>
                            <p class="text-dark-700 text-sm">Hotels, Budget Hotels, Resorts, Villas</p>
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>

    <section>
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-4">Frequently Asked Questions</h2>
        <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-8 w-32"></div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-primary-100 rounded-md shadow-md p-4 sm:p-6 transition-normal hover:shadow-lg">
                <h3 class="text-lg sm:text-xl font-bold text-dark-800 mb-2 flex items-center"><i class="fas fa-question-circle text-primary mr-2"></i> How to book a hotel?</h3>
                <p class="text-dark-700 text-sm sm:text-base">
                    Choose destination, dates, rooms, and search. Use filters for price and amenities, then continue to booking.
                </p>
            </div>
            <div class="bg-primary-100 rounded-md shadow-md p-4 sm:p-6 transition-normal hover:shadow-lg">
                <h3 class="text-lg sm:text-xl font-bold text-dark-800 mb-2 flex items-center"><i class="fas fa-question-circle text-primary mr-2"></i> How to find cheaper deals?</h3>
                <p class="text-dark-700 text-sm sm:text-base">
                    Filter by lower ranges and compare cities and dates. Sorting by low-to-high helps surface the best value options first.
                </p>
            </div>
        </div>
    </section>
</section>

<script>
    const searchBox = document.getElementById('searchBox');
    const suggestionsBox = document.getElementById('suggestions');
    const searchQuery = document.getElementById('searchQuery');
    const popularList = document.getElementById('popular-list');

    const cities = ['Goa', 'Ooty', 'Manali', 'Jaipur', 'Mumbai', 'Delhi', 'Banglore', 'Shimla', 'Ujjain', 'Udaipur'];

    searchBox.addEventListener('input', () => {
        const query = searchBox.value.toLowerCase().trim();
        suggestionsBox.classList.toggle('hidden', query.length === 0);
        searchQuery.textContent = query || 'Type a city...';

        if (query) {
            const filteredCities = cities.filter(city => city.toLowerCase().includes(query));
            popularList.innerHTML = filteredCities.length
                ? filteredCities.map(city => `<p class="text-dark-700 hover:text-primary-600 hover:bg-primary-100 px-2 py-1 cursor-pointer transition-normal">${city}</p>`).join('')
                : '<p class="text-dark-700">No cities found</p>';
        } else {
            popularList.innerHTML = cities.map(city => `<p class="text-dark-700 hover:text-primary-600 hover:bg-primary-100 px-2 py-1 cursor-pointer transition-normal">${city}</p>`).join('');
        }
    });

    popularList.addEventListener('click', (e) => {
        if (e.target.tagName === 'P') {
            searchBox.value = e.target.textContent;
            suggestionsBox.classList.add('hidden');
        }
    });

    document.addEventListener('click', (e) => {
        if (!suggestionsBox.contains(e.target) && e.target !== searchBox) {
            suggestionsBox.classList.add('hidden');
        }
    });
</script>
