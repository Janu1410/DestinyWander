@model List<backend.Hotel.Models.HotelViewModel>

@{
    ViewBag.Title = "Popular Hotels in Ujjain";
    ViewData["Title"] = "Popular Hotels in Ujjain";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
        :root {
            /* Terra Cotta Color Palette */
            --primary: #DF6951;
            --primary-100: #F9E2DD;
            --primary-200: #F2C5BB;
            --primary-300: #EBA799;
            --primary-400: #E58A77;
            --primary-600: #C85E47;
            --primary-700: #B1533D;
            --primary-800: #9A4833;
            --white: #FFFFFF;
            --light-100: #FDF9F8;
            --light-200: #FAF3F2;
            --light-300: #F5EDEB;
            --gray-400: #D7CECB;
            --gray-500: #A89B97;
            --gray-600: #796A65;
            --dark-700: #4A3D39;
            --dark-800: #2E2522;
            --dark-900: #1A1210;
            --border-radius-sm: 6px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
            --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
            --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        /* Custom Tailwind utilities */
        .bg-primary { background-color: var(--primary); }
        .bg-primary-100 { background-color: var(--primary-100); }
        .bg-primary-200 { background-color: var(--primary-200); }
        .bg-primary-600 { background-color: var(--primary-600); }
        .text-primary { color: var(--primary); }
        .text-primary-600 { color: var(--primary-600); }
        .text-primary-800 { color: var(--primary-800); }
        .text-dark-700 { color: var(--dark-700); }
        .text-dark-800 { color: var(--dark-800); }
        .border-light-300 { border-color: var(--light-300); }
        .shadow-sm { box-shadow: var(--shadow-sm); }
        .shadow-md { box-shadow: var(--shadow-md); }
        .shadow-lg { box-shadow: var(--shadow-lg); }
        .transition-normal { transition: var(--transition-normal); }

        /* Gradient for headers and buttons */
        .gradient-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
        }

       
    </style>

<div class="container mx-auto px-4 max-w-6xl">
        <!-- Header -->
        <div class="mb-8 fade-in">
            <h2 class="text-3xl font-bold text-dark-800">Popular Hotels in Ujjain</h2>
            <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mt-2 w-32"></div>
        </div>

        <!-- Hotel Cards -->
        @if (Model != null && Model.Count > 0)
        {
            foreach (var hotel in Model)
            {
                <div class="bg-white rounded-md shadow-md w-full sm:w-3/4 lg:w-2/3 mx-auto mb-6 overflow-hidden transition-normal hover:shadow-lg fade-in">
                    <div class="flex flex-col sm:flex-row justify-between p-4 gap-4">
                        <!-- Hotel Left -->
                        <div class="flex flex-col sm:flex-row w-full sm:w-2/3 gap-4">
                            <img src="@(hotel.ImageUrl ?? "https://via.placeholder.com/200x140")" alt="@hotel.Name" class="w-full sm:w-48 h-48 sm:h-36 object-cover rounded-md">
                            <div class="flex flex-col justify-between flex-1 overflow-hidden">
                                <h3 class="text-xl font-bold text-dark-800">@hotel.Name</h3>
                                <ul class="list-none p-0 text-sm text-dark-700">
                                    <li><i class="fas fa-check text-primary mr-2"></i> Free Cancellation till check-in</li>
                                    <li><i class="fas fa-check text-primary mr-2"></i> Book with &#8377;0 Payment</li>
                                </ul>
                                <p class="text-sm text-gray-500 truncate max-w-xs overflow-hidden whitespace-nowrap">@hotel.Address...</p>
                                <div class="bg-primary-100 text-primary-800 px-3 py-2 rounded-md mt-2 text-sm font-medium">
                                    <i class="fas fa-tag mr-1"></i> Flat &#8377;200 Off
                                </div>
                            </div>
                        </div>

                        <!-- Price Section -->
                        <div class="w-full sm:w-1/3 text-right mt-4 sm:mt-0">
                            <div class="flex justify-end items-center">
                                <span class="text-primary-600 font-bold text-sm mr-2">Good</span>
                                <span class="bg-primary-600 text-white px-2 py-1 rounded-md text-sm font-bold">@(hotel.Rating )</span>
                            </div>
                            <p class="text-xs text-gray-500">(@(hotel.ReviewCount ) Ratings)</p>
                            <div class="mt-2">
                                <p class="text-sm text-gray-500 line-through">&#8377;@((hotel.PricePerNight + 200).ToString("0"))</p>
                                <p class="text-xl font-bold text-dark-800">&#8377;@hotel.PricePerNight.ToString("0")</p>
                                <p class="text-xs text-gray-600">+ &#8377;180 taxes & fees<br>Per Night</p>
                            </div>
                            <a href="@Url.Action("Details", "Hotel", new { id = hotel.Id })" class="gradient-primary text-white font-semibold py-2 px-4 rounded-md mt-4 inline-flex items-center shadow-md hover:shadow-lg transition-normal transform hover:-translate-y-1" aria-label="Book @hotel.Name">
                                <i class="fas fa-book mr-2"></i> Book Now
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-dark-700 text-center w-full sm:w-3/4 lg:w-2/3 mx-auto fade-in">No hotels found.</p>
        }
    </div>




