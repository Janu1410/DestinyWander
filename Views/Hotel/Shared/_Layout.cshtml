<script src="https://cdn.tailwindcss.com"></script> -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
 <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<nav class="gradient-primary text-white fixed w-full top-0 z-50 shadow-md fade-in">
    <div class="container mx-auto px-4 sm:px-6 flex items-center justify-between py-4">
        <!-- Logo -->
        <a href="@Url.Action("Index", "Home")" class="text-2xl font-bold flex items-center hover:text-primary-200 transition-normal" aria-label="Navigate to home page">
            Destiny Wander<span class="text-primary ml-1">→</span>
        </a>
        <!-- Desktop Menu -->
        <ul class="hidden md:flex space-x-6">
            <li>
                <a href="@Url.Action("Index", "Home")" class="hover:text-primary-200 transition-normal flex items-center" aria-label="Navigate to home">
                    <i class="fas fa-home mr-1"></i> Home
                </a>
            </li>
            <li>
                <a href="@Url.Action("AboutUs", "Home")" class="hover:text-primary-200 transition-normal flex items-center" aria-label="Learn about us">
                    <i class="fas fa-info-circle mr-1"></i> About Us
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Tour")" class="hover:text-primary-200 transition-normal flex items-center" aria-label="Explore holiday packages">
                    <i class="fas fa-suitcase mr-1"></i> Packages
                </a>
            </li>
        </ul>
        <!-- Mobile Menu Button -->
        <button class="md:hidden text-white focus:outline-none focus:ring-2 focus:ring-primary-200" id="menu-toggle" aria-label="Toggle navigation menu" aria-controls="mobile-menu">
            <i class="fas fa-bars text-2xl"></i>
        </button>
    </div>
    <!-- Mobile Menu -->
    <div class="hidden md:hidden bg-dark-900 bg-opacity-90 w-full absolute top-16 left-0 z-40" id="mobile-menu">
        <ul class="flex flex-col items-center space-y-4 py-4">
            <li>
                <a href="@Url.Action("Index", "Home")" class="text-white hover:text-primary-200 transition-normal flex items-center" aria-label="Navigate to home">
                    <i class="fas fa-home mr-1"></i> Home
                </a>
            </li>
            <li>
                <a href="@Url.Action("AboutUs", "Home")" class="text-white hover:text-primary-200 transition-normal flex items-center" aria-label="Learn about us">
                    <i class="fas fa-info-circle mr-1"></i> About Us
                </a>
            </li>
            <li>
                <a href="@Url.Action("Index", "Tour")" class="text-white hover:text-primary-200 transition-normal flex items-center" aria-label="Explore holiday packages">
                    <i class="fas fa-suitcase mr-1"></i> Packages
                </a>
            </li>
        </ul>
    </div>
</nav>

<style>
    :root {
        /* Terra Cotta Color Palette */
        --primary: #DF6951;
        --primary-100: #F9E2DD;
        --primary-200: #F2C5BB;
        --primary-300: #EBA799;
        --primary-400: #E58A77;
        --primary-600: #C85E47;
        --primary-700: #B1533D;
        --primary-800: #9A4833;
        --white: #FFFFFF;
        --light-100: #FDF9F8;
        --light-200: #FAF3F2;
        --light-300: #F5EDEB;
        --gray-400: #D7CECB;
        --gray-500: #A89B97;
        --gray-600: #796A65;
        --dark-700: #4A3D39;
        --dark-800: #2E2522;
        --dark-900: #1A1210;
        --border-radius-sm: 6px;
        --border-radius-md: 12px;
        --border-radius-lg: 20px;
        --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
        --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
        --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
        --transition-fast: 0.15s ease;
        --transition-normal: 0.3s ease;
        --transition-slow: 0.5s ease;
    }

    /* Custom Tailwind utilities */
    .bg-primary { background-color: var(--primary); }
    .bg-primary-100 { background-color: var(--primary-100); }
    .bg-primary-200 { background-color: var(--primary-200); }
    .bg-primary-600 { background-color: var(--primary-600); }
    .text-primary { color: var(--primary); }
    .text-primary-600 { color: var(--primary-600); }
    .text-dark-700 { color: var(--dark-700); }
    .text-dark-800 { color: var(--dark-800); }
    .border-light-300 { border-color: var(--light-300); }
    .border-primary-200 { border-color: var(--primary-200); }
    .shadow-sm { box-shadow: var(--shadow-sm); }
    .shadow-md { box-shadow: var(--shadow-md); }
    .shadow-lg { box-shadow: var(--shadow-lg); }
    .transition-normal { transition: var(--transition-normal); }

    /* Gradient for navbar */
    .gradient-primary {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
    }

    /* Fade-in animation */
   
   
    /* Ensure Poppins font */
    nav {
        font-family: 'Poppins', sans-serif;
    }
</style>

<!-- JavaScript for Mobile Menu -->
<script>
    // Mobile Menu Toggle
    document.getElementById('menu-toggle').addEventListener('click', () => {
        const mobileMenu = document.getElementById('mobile-menu');
        mobileMenu.classList.toggle('hidden');
    });
</script>


<body>
    @await Html.PartialAsync("_Navbar")
    @RenderBody()
    @await Html.PartialAsync("_Footer")
</body>




    <main>
        @RenderBody()
    </main>

  

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="~/lib/microsoft.jquery.unobtrusive-ajax/jquery.unobtrusive-ajax.min.js"></script>
}

 @RenderSection("Scripts", required: false)
