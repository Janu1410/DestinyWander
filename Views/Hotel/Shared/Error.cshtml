@{
    ViewData["Title"] = "Hotel Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container mx-auto px-4 sm:px-6 max-w-3xl py-8">
    <div class="bg-white rounded-md shadow-md border border-primary-200 p-6 sm:p-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-3">Hotel Service Error</h2>
        @if (ViewBag.ErrorMessage != null)
        {
            <p class="text-dark-700 mb-6">@ViewBag.ErrorMessage</p>
        }
        else
        {
            <p class="text-dark-700 mb-6">An unexpected error occurred. Please try again.</p>
        }
        <a href="/api/hotel/index" class="gradient-primary text-white font-semibold py-2.5 px-6 rounded-md inline-flex items-center shadow-md hover:shadow-lg transition-normal">
            <i class="fas fa-hotel mr-2"></i> Back To Hotels
        </a>
    </div>
</section>
