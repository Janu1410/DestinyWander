@{
    ViewData["Title"] = "Secure Payment";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var user = "Dhruvi Jingar";
    var amount = "3500";
    var orderId = "ORD123456";
    var origin = "Delhi (DEL)";
    var destination = "Chennai (MAA)";
}

<section class="container mx-auto px-4 sm:px-6 max-w-3xl py-8">
    <div class="bg-white rounded-md shadow-md border border-primary-200 overflow-hidden">
        <div class="gradient-primary p-6">
            <h2 class="text-2xl sm:text-3xl font-bold text-white">Secure Payment</h2>
            <p class="text-primary-100 mt-1">Order ID: @orderId</p>
        </div>

        <div class="p-6 sm:p-8">
            <div class="bg-primary-100 rounded-md p-4 mb-6 grid grid-cols-1 sm:grid-cols-2 gap-3 text-dark-700">
                <p><strong>User:</strong> @user</p>
                <p><strong>Amount:</strong> &#8377;@amount</p>
                <p><strong>From:</strong> @origin</p>
                <p><strong>To:</strong> @destination</p>
            </div>

            <form method="get" action="/PaymentStatus" class="space-y-4">
                <input type="hidden" name="status" value="success" />
                <input type="hidden" name="orderId" value="@orderId" />

                <div>
                    <label class="block text-sm font-medium text-dark-700 mb-1" for="cardName">Cardholder Name</label>
                    <input id="cardName" type="text" name="cardName" class="w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="e.g. Dhruvi Jingar" value="Dhruvi Jingar" required />
                </div>

                <div>
                    <label class="block text-sm font-medium text-dark-700 mb-1" for="cardNumber">Card Number</label>
                    <input id="cardNumber" type="tel" name="cardNumber" class="w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="1234 5678 9012 3456" maxlength="19" value="1234 5678 9012 3456" required />
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-dark-700 mb-1" for="expiry">Expiry Date</label>
                        <input id="expiry" type="text" name="expiry" class="w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="MM/YY" maxlength="5" value="12/28" required />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-700 mb-1" for="cvv">CVV</label>
                        <input id="cvv" type="password" name="cvv" class="w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="123" maxlength="4" value="123" required />
                    </div>
                </div>

                <button type="submit" class="w-full gradient-primary text-white font-semibold py-3 px-4 rounded-md shadow-md hover:shadow-lg transition-normal transform hover:-translate-y-1">
                    Pay &#8377;@amount
                </button>
            </form>
        </div>
    </div>
</section>
