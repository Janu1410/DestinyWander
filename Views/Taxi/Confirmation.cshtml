
@model backend.Taxi.Models.TaxiBooking
@{
    ViewData["Title"] = "Taxi Booking Confirmation";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            /* Terra Cotta Color Palette */
            --primary: #DF6951;
            --primary-100: #F9E2DD;
            --primary-200: #F2C5BB;
            --primary-300: #EBA799;
            --primary-400: #E58A77;
            --primary-600: #C85E47;
            --primary-700: #B1533D;
            --primary-800: #9A4833;
            --white: #FFFFFF;
            --light-100: #FDF9F8;
            --light-200: #FAF3F2;
            --light-300: #F5EDEB;
            --gray-400: #D7CECB;
            --gray-500: #A89B97;
            --gray-600: #796A65;
            --dark-700: #4A3D39;
            --dark-800: #2E2522;
            --dark-900: #1A1210;
            --border-radius-sm: 6px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
            --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
            --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        /* Custom Tailwind utilities */
        .bg-primary { background-color: var(--primary); }
        .bg-primary-100 { background-color: var(--primary-100); }
        .bg-primary-200 { background-color: var(--primary-200); }
        .bg-primary-300 { background-color: var(--primary-300); }
        .bg-primary-600 { background-color: var(--primary-600); }
        .text-primary { color: var(--primary); }
        .text-primary-800 { color: var(--primary-800); }
        .text-dark-700 { color: var(--dark-700); }
        .text-dark-800 { color: var(--dark-800); }
        .border-primary-300 { border-color: var(--primary-300); }
        .shadow-sm { box-shadow: var(--shadow-sm); }
        .shadow-md { box-shadow: var(--shadow-md); }
        .shadow-lg { box-shadow: var(--shadow-lg); }
        .transition-normal { transition: var(--transition-normal); }

        /* Gradient for card header */
        .header-gradient {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
        }
    </style>
</head>
<body class="bg-light-100 text-dark-800 font-sans antialiased">
    <div class="container mx-auto px-4 py-10">
        <div class="flex justify-center">
            <div class="w-full max-w-2xl">
                <div class="bg-white rounded-lg shadow-lg transform transition-transform duration-500 hover:scale-105">
                    <div class="header-gradient text-white p-6 rounded-t-lg">
                        <h3 class="text-2xl md:text-3xl font-bold text-center">Booking Confirmed!</h3>
                    </div>
                    <div class="p-6 md:p-8">
                        <div class="bg-primary-100 border-l-4 border-primary p-4 rounded-md flex items-start space-x-3">
                            <svg class="w-6 h-6 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                            <div>
                                <h4 class="text-lg font-semibold text-dark-800">Thank you for your booking!</h4>
                                <p class="text-dark-700">Your taxi booking has been confirmed. Here are your booking details:</p>
                            </div>
                        </div>

                        <div class="bg-primary-200 p-6 rounded-lg mt-6 border border-primary-300">
                            <h5 class="text-xl font-semibold text-dark-800 mb-4">Booking Summary</h5>
                            <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full mb-4"></div>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <p class="text-dark-700"><strong>Booking ID:</strong> @Model.Id</p>
                                    <p class="text-dark-700"><strong>Vehicle Type:</strong> @Model.VehicleType</p>
                                    <p class="text-dark-700"><strong>Supplier:</strong> @Model.SupplierName</p>
                                </div>
                                <div>
                                    <p class="text-dark-700"><strong>Pickup Location:</strong> @Model.PickupLocation</p>
                                    <p class="text-dark-700"><strong>Drop-off Location:</strong> @Model.DropOffLocation</p>
                                    <p class="text-dark-700"><strong>Pickup Date & Time:</strong> @Model.PickUpDateTime</p>
                                </div>
                            </div>
                            <div class="mt-4">
                                <p class="text-dark-700"><strong>Duration:</strong> @Model.Duration</p>
                                <p class="text-dark-700"><strong>Total Amount:</strong> @Model.PriceAmount</p>
                            </div>
                        </div>

                        <div class="mt-6 text-center">
                            <a href="/" class="inline-block bg-primary text-white font-semibold py-3 px-8 rounded-lg shadow-md hover:bg-primary-600 hover:shadow-lg transition-normal transform hover:-translate-y-1">
                                Return to Home
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
