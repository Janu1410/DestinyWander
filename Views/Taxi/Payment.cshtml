@model backend.Taxi.Models.TaxiBooking
@{
    ViewData["Title"] = "Taxi Payment";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            /* Terra Cotta Color Palette */
            --primary: #DF6951;
            --primary-100: #F9E2DD;
            --primary-200: #F2C5BB;
            --primary-300: #EBA799;
            --primary-400: #E58A77;
            --primary-600: #C85E47;
            --primary-700: #B1533D;
            --primary-800: #9A4833;
            --white: #FFFFFF;
            --light-100: #FDF9F8;
            --light-200: #FAF3F2;
            --light-300: #F5EDEB;
            --gray-400: #D7CECB;
            --gray-500: #A89B97;
            --gray-600: #796A65;
            --dark-700: #4A3D39;
            --dark-800: #2E2522;
            --dark-900: #1A1210;
            --border-radius-sm: 6px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
            --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
            --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        /* Custom Tailwind utilities */
        .bg-primary { background-color: var(--primary); }
        .bg-primary-100 { background-color: var(--primary-100); }
        .bg-primary-200 { background-color: var(--primary-200); }
        .bg-primary-300 { background-color: var(--primary-300); }
        .bg-primary-600 { background-color: var(--primary-600); }
        .text-primary { color: var(--primary); }
        .text-primary-800 { color: var(--primary-800); }
        .text-dark-700 { color: var(--dark-700); }
        .text-dark-800 { color: var(--dark-800); }
        .border-primary-300 { border-color: var(--primary-300); }
        .shadow-sm { box-shadow: var(--shadow-sm); }
        .shadow-md { box-shadow: var(--shadow-md); }
        .shadow-lg { box-shadow: var(--shadow-lg); }
        .transition-normal { transition: var(--transition-normal); }

        /* Gradient for header */
        .header-gradient {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
        }
    </style>
</head>
<body class="bg-light-100 min-h-screen flex items-center justify-center p-4 sm:p-6">
    <div class="max-w-md w-full">
        <!-- Payment Card -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden transform transition-transform duration-500 hover:scale-105">
            <!-- Card Header -->
            <div class="header-gradient p-6 text-center">
                <h2 class="text-2xl sm:text-3xl font-bold text-white">Taxi Payment</h2>
                <p class="text-primary-100 mt-1 text-sm sm:text-base">Booking #@Model.Id</p>
            </div>

            <!-- Card Body -->
            <div class="p-6 sm:p-8">
                <!-- Payment Summary -->
                <div class="mb-6 p-4 bg-primary-200 rounded-md border border-primary-300">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-dark-700 text-sm sm:text-base">Trip Fare:</span>
                        <span class="font-medium text-dark-800">@Model.PriceAmount</span>
                    </div>
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-dark-700 text-sm sm:text-base">Service Fee:</span>
                        <span class="font-medium text-dark-800">$2.50</span>
                    </div>
                    <div class="h-1 bg-gradient-to-r from-primary to-primary-600 rounded-full my-3"></div>
                    <div class="flex justify-between items-center">
                        <span class="text-dark-800 font-bold text-sm sm:text-base">Total:</span>
                        <span class="text-primary-800 font-bold text-lg">@((decimal.Parse(Model.PriceAmount.Replace("$", "")) + 2.50m).ToString("C"))</span>
                    </div>
                </div>

                <!-- Payment Form -->
                <form id="paymentForm">
                    <!-- Card Number -->
                    <div class="mb-4">
                        <label for="cardNumber" class="block text-sm font-medium text-dark-700 mb-1">Card Number</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="far fa-credit-card text-gray-400"></i>
                            </div>
                            <input type="text" id="cardNumber" placeholder="1234 5678 9012 3456"
                                class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal"
                                required>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-4">
                        <!-- Expiry Date -->
                        <div>
                            <label for="expiryDate" class="block text-sm font-medium text-dark-700 mb-1">Expiry Date</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="far fa-calendar-alt text-gray-400"></i>
                                </div>
                                <input type="text" id="expiryDate" placeholder="MM/YY"
                                    class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal"
                                    required>
                            </div>
                        </div>

                        <!-- CVV -->
                        <div>
                            <label for="cvv" class="block text-sm font-medium text-dark-700 mb-1">CVV</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="fas fa-lock text-gray-400"></i>
                                </div>
                                <input type="text" id="cvv" placeholder="123"
                                    class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal"
                                    required>
                            </div>
                        </div>
                    </div>

                    <!-- Card Holder Name -->
                    <div class="mb-6">
                        <label for="cardHolder" class="block text-sm font-medium text-dark-700 mb-1">Card Holder Name</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="far fa-user text-gray-400"></i>
                            </div>
                            <input type="text" id="cardHolder" placeholder="John Doe"
                                class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal"
                                required>
                        </div>
                    </div>

                    <!-- Payment Button -->
                    <button type="button" onclick="payNow('@Model.Id')"
                        class="w-full bg-primary hover:bg-primary-600 text-white font-semibold py-3 px-4 rounded-md shadow-md hover:shadow-lg transition-normal transform hover:-translate-y-1 flex items-center justify-center">
                        <i class="fas fa-lock mr-2"></i> Pay @((decimal.Parse(Model.PriceAmount.Replace("$", "")) + 2.50m).ToString("C"))
                    </button>

                    <!-- Security Info -->
                    <div class="mt-4 flex items-center justify-center">
                        <i class="fas fa-shield-alt text-primary-600 mr-2"></i>
                        <span class="text-xs text-gray-600">Your payment is secure and encrypted</span>
                    </div>
                </form>
            </div>
        </div>

        <!-- Payment Methods -->
        <div class="mt-6 flex flex-wrap justify-center gap-4">
            <div class="bg-white p-2 rounded-md shadow-sm hover:shadow-md transition-normal">
                <img src="https://logo.clearbit.com/visa.com" alt="Visa" class="h-6">
            </div>
            <div class="bg-white p-2 rounded-md shadow-sm hover:shadow-md transition-normal">
                <img src="https://logo.clearbit.com/mastercard.com" alt="Mastercard" class="h-6">
            </div>
            <div class="bg-white p-2 rounded-md shadow-sm hover:shadow-md transition-normal">
                <img src="https://logo.clearbit.com/americanexpress.com" alt="Amex" class="h-6">
            </div>
        </div>
    </div>

    <script>
        function payNow(bookingId) {
            if (bookingId) {
                window.location.href = `/api/taxi/success?bookingId=${bookingId}`;
            } else {
                alert("Booking ID is missing!");
            }
        }
    </script>
</body>
</html>
