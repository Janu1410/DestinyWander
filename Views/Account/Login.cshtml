@model backend.Auth.Models.LoginViewModel

@{
    ViewBag.Title = "Login";
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
        :root {
            /* Terra Cotta Color Palette */
            --primary: #DF6951;
            --primary-100: #F9E2DD;
            --primary-200: #F2C5BB;
            --primary-300: #EBA799;
            --primary-400: #E58A77;
            --primary-600: #C85E47;
            --primary-700: #B1533D;
            --primary-800: #9A4833;
            --white: #FFFFFF;
            --light-100: #FDF9F8;
            --light-200: #FAF3F2;
            --light-300: #F5EDEB;
            --gray-400: #D7CECB;
            --gray-500: #A89B97;
            --gray-600: #796A65;
            --dark-700: #4A3D39;
            --dark-800: #2E2522;
            --dark-900: #1A1210;
            --red-100: #FEE2E2;
            --red-600: #DC2626;
            --green-100: #DCFCE7;
            --green-600: #16A34A;
            --border-radius-sm: 6px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
            --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
            --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        /* Custom Tailwind utilities */
        .bg-primary { background-color: var(--primary); }
        .bg-primary-100 { background-color: var(--primary-100); }
        .bg-primary-200 { background-color: var(--primary-200); }
        .bg-primary-600 { background-color: var(--primary-600); }
        .text-primary { color: var(--primary); }
        .text-primary-600 { color: var(--primary-600); }
        .text-dark-700 { color: var(--dark-700); }
        .text-dark-800 { color: var(--dark-800); }
        .border-light-300 { border-color: var(--light-300); }
        .border-primary-200 { border-color: var(--primary-200); }
        .shadow-sm { box-shadow: var(--shadow-sm); }
        .shadow-md { box-shadow: var(--shadow-md); }
        .shadow-lg { box-shadow: var(--shadow-lg); }
        .transition-normal { transition: var(--transition-normal); }

        /* Gradient for buttons */
        .gradient-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
        }

        /* Fade-in animation */
       

        /* Ensure Poppins font */
        body {
            font-family: 'Poppins', sans-serif;
        }
    </style>

<div class="container mx-auto px-4 sm:px-6 max-w-md">
        <div class="bg-white rounded-md shadow-md p-6 sm:p-8 border border-primary-200 fade-in">
            <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-2 text-center">Login</h2>
            <p class="text-dark-700 text-center mb-6">Login to access your account</p>

            <!-- Success Message -->
            @if (TempData["Success"] != null)
            {
                <div class="bg-green-100 text-green-600 p-4 rounded-md shadow-md mb-6 text-center fade-in">@TempData["Success"]</div>
            }

            <!-- Validation Summary -->
            @Html.ValidationSummary(true, "", new { @class = "bg-red-100 text-red-600 p-4 rounded-md shadow-md mb-6 text-sm text-center fade-in" })

            <form asp-controller="Account" asp-action="Login" method="post" class="space-y-6">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div class="relative">
                    <label for="Email" class="block text-sm font-medium text-dark-800 mb-1">Email</label>
                    <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-envelope text-gray-500"></i>
                    </div>
                    <input asp-for="Email" type="email" placeholder="Email" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                </div>
                <div class="relative">
                    <label for="Password" class="block text-sm font-medium text-dark-800 mb-1">Password</label>
                    <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-lock text-gray-500"></i>
                    </div>
                    <input asp-for="Password" type="password" placeholder="Password" required class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" />
                </div>

                <div class="flex items-center justify-between">
                    <label class="inline-flex items-center text-sm text-dark-700">
                        <input asp-for="RememberMe" type="checkbox" class="mr-2 h-4 w-4 text-primary-600 border-light-300 rounded focus:ring-primary-200">
                        Stay signed in
                    </label>
                </div>
                
                <div class="text-center">
                    <button type="submit" class="gradient-primary text-white font-semibold py-2 px-6 rounded-md shadow-md hover:shadow-lg transition-normal transform hover:-translate-y-1 focus:ring-2 focus:ring-primary-200 focus:outline-none w-full sm:w-auto" aria-label="Login to account">
                        <i class="fas fa-sign-in-alt mr-2"></i> Login
                    </button>
                </div>
                <div class="text-center">
                    <a href="/Account/GoogleLogin" class="bg-red-600 text-white font-semibold py-2 px-6 rounded-md shadow-md hover:shadow-lg transition-normal inline-flex items-center w-full sm:w-auto justify-center mt-4" aria-label="Login with Google">
                        <i class="fab fa-google mr-2"></i> Login with Google
                    </a>
                </div>
                <p class="text-center text-dark-700 text-sm mt-4">
                    Don't have an account? <a asp-action="SignUp" asp-controller="Account" class="text-primary-600 hover:underline">Sign up</a>
                </p>
            </form>
        </div>
    </div>

    <!-- Validation Scripts -->
    @section Scripts {
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    }



