@model backend.Auth.Models.UserViewModel

@{
    ViewBag.Title = "Sign Up";
    ViewData["Title"] = "Sign Up";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
        :root {
            /* Terra Cotta Color Palette */
            --primary: #DF6951;
            --primary-100: #F9E2DD;
            --primary-200: #F2C5BB;
            --primary-300: #EBA799;
            --primary-400: #E58A77;
            --primary-600: #C85E47;
            --primary-700: #B1533D;
            --primary-800: #9A4833;
            --white: #FFFFFF;
            --light-100: #FDF9F8;
            --light-200: #FAF3F2;
            --light-300: #F5EDEB;
            --gray-400: #D7CECB;
            --gray-500: #A89B97;
            --gray-600: #796A65;
            --dark-700: #4A3D39;
            --dark-800: #2E2522;
            --dark-900: #1A1210;
            --red-100: #FEE2E2;
            --red-600: #DC2626;
            --border-radius-sm: 6px;
            --border-radius-md: 12px;
            --border-radius-lg: 20px;
            --shadow-sm: 0 2px 8px rgba(46, 42, 40, 0.08);
            --shadow-md: 0 4px 16px rgba(46, 42, 40, 0.12);
            --shadow-lg: 0 8px 24px rgba(46, 42, 40, 0.16);
            --transition-fast: 0.15s ease;
            --transition-normal: 0.3s ease;
            --transition-slow: 0.5s ease;
        }

        /* Custom Tailwind utilities */
        .bg-primary { background-color: var(--primary); }
        .bg-primary-100 { background-color: var(--primary-100); }
        .bg-primary-200 { background-color: var(--primary-200); }
        .bg-primary-600 { background-color: var(--primary-600); }
        .text-primary { color: var(--primary); }
        .text-primary-600 { color: var(--primary-600); }
        .text-dark-700 { color: var(--dark-700); }
        .text-dark-800 { color: var(--dark-800); }
        .border-light-300 { border-color: var(--light-300); }
        .border-primary-200 { border-color: var(--primary-200); }
        .shadow-sm { box-shadow: var(--shadow-sm); }
        .shadow-md { box-shadow: var(--shadow-md); }
        .shadow-lg { box-shadow: var(--shadow-lg); }
        .transition-normal { transition: var(--transition-normal); }

        /* Gradient for buttons */
        .gradient-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-600) 100%);
        }

        /* Fade-in animation */
      

        /* Ensure Poppins font */
        body {
            font-family: 'Poppins', sans-serif;
        }
    </style>

<div class="container mx-auto px-4 sm:px-6 max-w-lg">
        <div class="bg-white rounded-md shadow-md p-6 sm:p-8 border border-primary-200 fade-in">
            <h2 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-2 text-center">Sign Up</h2>
            <p class="text-dark-700 text-center mb-6">Let's get you set up for your personal account.</p>
            <form asp-action="SignUp" asp-controller="Account" method="post" class="space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="relative">
                        <label for="FirstName" class="block text-sm font-medium text-dark-800 mb-1">First Name</label>
                        <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-user text-gray-500"></i>
                        </div>
                        <input asp-for="FirstName" class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="First Name" />
                        <span asp-validation-for="FirstName" class="text-red-600 text-sm mt-1 block"></span>
                    </div>
                    <div class="relative">
                        <label for="LastName" class="block text-sm font-medium text-dark-800 mb-1">Last Name</label>
                        <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-user text-gray-500"></i>
                        </div>
                        <input asp-for="LastName" class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="Last Name" />
                        <span asp-validation-for="LastName" class="text-red-600 text-sm mt-1 block"></span>
                    </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="relative">
                        <label for="Email" class="block text-sm font-medium text-dark-800 mb-1">Email</label>
                        <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-envelope text-gray-500"></i>
                        </div>
                        <input asp-for="Email" class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="Email" />
                        <span asp-validation-for="Email" class="text-red-600 text-sm mt-1 block"></span>
                    </div>
                    <div class="relative">
                        <label for="Phone" class="block text-sm font-medium text-dark-800 mb-1">Phone Number</label>
                        <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-phone text-gray-500"></i>
                        </div>
                        <input asp-for="Phone" class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="Phone Number" />
                        <span asp-validation-for="Phone" class="text-red-600 text-sm mt-1 block"></span>
                    </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="relative">
                        <label for="Password" class="block text-sm font-medium text-dark-800 mb-1">Password</label>
                        <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-gray-500"></i>
                        </div>
                        <input asp-for="Password" class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="Password" type="password" />
                        <p class="text-xs text-gray-500 mt-1">Use 10+ chars with uppercase, lowercase, number, and symbol.</p>
                        <span asp-validation-for="Password" class="text-red-600 text-sm mt-1 block"></span>
                    </div>
                    <div class="relative">
                        <label for="ConfirmPassword" class="block text-sm font-medium text-dark-800 mb-1">Confirm Password</label>
                        <div class="absolute inset-y-0 left-0 top-6 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-gray-500"></i>
                        </div>
                        <input asp-for="ConfirmPassword" class="pl-10 w-full border border-light-300 rounded-md py-2.5 px-3 text-dark-700 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-normal" placeholder="Confirm Password" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-red-600 text-sm mt-1 block"></span>
                    </div>
                </div>
                <div class="flex items-center">
                    <input asp-for="AgreeToTerms" type="checkbox" id="AgreeToTerms" class="h-4 w-4 text-primary-600 border-gray-300 rounded focus:ring-primary-200" />
                    <label for="AgreeToTerms" class="ml-2 text-sm text-dark-700">I agree to the <a href="#" class="text-primary-600 hover:underline">Terms</a> and <a href="#" class="text-primary-600 hover:underline">Privacy Policies</a></label>
                    <span asp-validation-for="AgreeToTerms" class="text-red-600 text-sm ml-2"></span>
                </div>
                <div class="text-center">
                    <button type="submit" class="gradient-primary text-white font-semibold py-2 px-6 rounded-md shadow-md hover:shadow-lg transition-normal transform hover:-translate-y-1 focus:ring-2 focus:ring-primary-200 focus:outline-none w-full sm:w-auto" aria-label="Create account">
                        <i class="fas fa-user-plus mr-2"></i> Create Account
                    </button>
                </div>
                <p class="text-center text-dark-700 text-sm mt-4">
                    Already have an account? <a asp-action="Login" asp-controller="Account" class="text-primary-600 hover:underline">Login</a>
                </p>
            </form>
        </div>
    </div>

    <!-- Validation Scripts -->
    @section Scripts {
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    }



