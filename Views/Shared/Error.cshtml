@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="container mx-auto px-4 sm:px-6 max-w-3xl py-8">
    <div class="bg-white rounded-md shadow-md border border-primary-200 p-6 sm:p-8">
        <h1 class="text-2xl sm:text-3xl font-bold text-dark-800 mb-3">Something Went Wrong</h1>
        <p class="text-dark-700 mb-4">An unexpected error occurred while processing your request.</p>

        @if (Model?.ShowRequestId == true)
        {
            <p class="text-sm text-gray-600 mb-4">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <div class="bg-primary-100 rounded-md p-4 text-dark-700 text-sm">
            For local troubleshooting, use the <strong>Development</strong> environment to see full exception details.
        </div>
    </div>
</section>
