@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isHome = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
    var isAbout = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, "About", StringComparison.OrdinalIgnoreCase);
    var isPackage = string.Equals(currentController, "Tour", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Package", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Payment", StringComparison.OrdinalIgnoreCase);
    var pageTitle = ViewData["Title"]?.ToString() ?? currentController;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Destiny Wander</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TravelWebsite.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="@(isHome ? "hero" : "inner-hero")">
        <div class="navbar">
            <div class="logo">Destiny Wander</div>
            <button class="dw-menu-btn" type="button" aria-label="Toggle menu" aria-controls="dw-main-nav" aria-expanded="false">
                <i class="fas fa-bars"></i>
            </button>
            <ul class="nav-links" id="dw-main-nav">
                <li><a class="@(isHome ? "active" : "")" asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a class="@(isAbout ? "active" : "")" asp-controller="Home" asp-action="About">About</a></li>
                <li><a class="@(isPackage ? "active" : "")" asp-controller="Tour" asp-action="Index">Holiday Package</a></li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var firstChar = User.Identity.Name?.FirstOrDefault().ToString().ToUpper();
                    <li class="profile-menu">
                        <div class="avatar-circle" title="Profile">@firstChar</div>
                        <div class="dropdown-content">
                            <p><strong>@User.Identity.Name</strong></p>
                            <p>@User.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress")?.Value</p>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="dw-logout-form">
                                <button type="submit" class="logout-btn">Logout</button>
                            </form>
                        </div>
                    </li>
                }
                else
                {
                    <li><a asp-controller="Account" asp-action="SignUp">Sign Up</a></li>
                    <li><a asp-controller="Account" asp-action="Login" class="login-btn">Login</a></li>
                }
            </ul>
        </div>

        @if (isHome)
        {
            <div class="transport-box">
                <a href="/api/flight"><img src="~/imagesH/flight.png" alt="Flights" /><p>Flights</p></a>
                <a href="/api/hotel/index"><img src="~/imagesH/hotel.png" alt="Hotels" /><p>Hotels</p></a>
                <a href="/Tour/Index" class="transport-wide"><img src="~/imagesH/package.png" alt="Holiday Packages" /><p>Holiday Packages</p></a>
                <a href="#"><img src="~/imagesH/train.png" alt="Trains" /><p>Trains</p></a>
                <a href="#"><img src="~/imagesH/bus.png" alt="Bus" /><p>Bus</p></a>
                <a href="/api/taxi"><img src="~/imagesH/taxi.png" alt="Taxi" /><p>Taxi</p></a>
            </div>
            <div class="travel">
                <p class="a1">BEST Destinations AROUND THE WORLD</p>
                <h1 class="a2">Travel, enjoy and live a new and full life</h1>
            </div>
        }
        else
        {
            <div class="inner-hero-content">
                <h1>@pageTitle</h1>
                <p>Plan smart, travel better with Destiny Wander.</p>
            </div>
        }
    </header>

    <main class="dw-page-shell">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-column">
                <h2 class="footer-brand">Destiny Wander</h2>
                <p class="footer-desc">Travel helps companies<br> manage payments easily.</p>
                <div class="footer-socials">
                    <a href="#"><i class="fab fa-linkedin-in"></i></a>
                </div>
            </div>

            <div class="footer-column">
                <h4>Company</h4>
                <ul>
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                    <li><a asp-controller="Tour" asp-action="Index">Holiday Package</a></li>
                </ul>
            </div>

            <div class="footer-column">
                <h4>Destinations</h4>
                <ul>
                    <li><a href="/api/hotel/manali">Manali</a></li>
                    <li><a href="/api/hotel/udaipur">Udaipur</a></li>
                    <li><a href="/api/hotel/goa">Goa</a></li>
                    <li><a href="/api/hotel/delhi">Delhi</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>Destiny Wander <span id="dw-year">2026</span>. All Rights Reserved.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        window.dwIsAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
